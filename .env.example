# ── Database ─────────────────────────────────────────────────────────────────
# MySQL connection string — Railway provides this automatically as ${{MySQL.DATABASE_URL}}
DATABASE_URL=mysql://user:password@host:3306/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
# Option A — Google AI Studio (recommended for external deployments)
# Get your key at: https://aistudio.google.com/app/apikey
BUILT_IN_FORGE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
BUILT_IN_FORGE_API_KEY=your-google-ai-api-key

# Option B — Manus Forge (only works when running inside Manus platform)
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=your-manus-forge-key

# ── Integrations ─────────────────────────────────────────────────────────────
# Pabbly Connect webhook for lead notifications (from your Pabbly workflow)
PABBLY_WEBHOOK_URL=https://connect.pabbly.com/workflow/sendwebhookdata/your-webhook-id

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
VITE_APP_ID=nightdesk-agency

# ── Optional (Manus OAuth — leave blank for external deployments) ─────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
